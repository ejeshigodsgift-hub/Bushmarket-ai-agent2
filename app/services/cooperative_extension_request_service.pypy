from sqlalchemy.ext.asyncio import AsyncSession
from fastapi import HTTPException

from app.db.models.cooperative_membership import CooperativeMembership
from app.db.models.cooperative_extension_vote import CooperativeExtensionVote


class CooperativeExtensionRequestService:
    """
    Handles user-triggered extension requests from dashboard.
    This is a shortcut: request = auto YES vote.
    """

    async def request_extension(
        self,
        db: AsyncSession,
        cooperative_id: str,
        membership_id: str
    ) -> CooperativeExtensionVote:

        # -------------------------------------
        # Validate membership
        # -------------------------------------
        membership = await db.get(
            CooperativeMembership,
            membership_id
        )

        if not membership:
            raise HTTPException(
                status_code=404,
                detail="Membership not found"
            )

        if membership.cooperative_id != cooperative_id:
            raise HTTPException(
                status_code=400,
                detail="Membership does not belong to cooperative"
            )

        if membership.status != "active":
            raise HTTPException(
                status_code=409,
                detail="Only active members can request extension"
            )

        # -------------------------------------
        # Prevent duplicate request (optional safety)
        # -------------------------------------
        # You can later enforce unique constraint in DB
        # For now we assume service-level guard

        # -------------------------------------
        # Create YES vote automatically
        # -------------------------------------
        vote = CooperativeExtensionVote(
            cooperative_id=cooperative_id,
            membership_id=membership_id,
            user_id=membership.user_id,
     round_number=cooperative.current_extension_round,
            vote=True
        )

        db.add(vote)
        await db.commit()
        await db.refresh(vote)

        return vote