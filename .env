# APP
APP_NAME=BushmarketBackend
ENV=development

# DATABASE
DATABASE_URL=postgresql+psycopg2://postgres_user:postgres_password@localhost:5432/bushmarket_db

# REDIS
REDIS_URL=redis://localhost:6379/0

# KAFKA
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=bushmarket-event-bus

KAFKA_AGENT_TASK_TOPIC=agent.task.created
KAFKA_AGENT_UPDATE_TOPIC=agent.task.updated

# SECURITY
SECRET_KEY=change_this_in_production

JWT_ALGORITHM=HS256
INTERNAL_JWT_EXPIRY_MINUTES=30

ACCESS_TOKEN_EXPIRE_MINUTES=60

COOKIE_NAME=bushmarket_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=localhost

SESSION_TTL=86400

# CSRF
CSRF_COOKIE_NAME=csrf_token
CSRF_HEADER_NAME=x-csrf-token

# RATE LIMITING
RATE_LIMIT_LOGIN_MAX_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=60